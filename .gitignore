# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/.next-bak*/
/out/

# production
/build

# misc
.DS_Store
*.pem
/relatorio.txt

# Generated public artifacts (auto-created by upkf:generate at build time)
# Do NOT commit these — they are ephemeral and regenerated on every build.
public/research/*.md
public/essays/*.md
public/whitepapers/*.md
public/acervo-teologico.md
public/acervo-teologico/**/*.md
public/essays.md
public/research.md
public/whitepapers.md
public/mundo-politico.md
public/mundo-politico/**/*.md
public/identidade.md
public/certifications.md
public/certifications/**/*.md
public/certificacoes.md
public/ensaios.md
public/pesquisa.md
public/simulacoes.md
public/simulacoes/**/*.md

# Generated PDFs (auto-created by upkf:generate — do not commit)
public/essays/*.pdf
public/research/*.pdf
public/whitepapers/*.pdf

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
