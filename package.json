{
  "name": "ulisses-hub",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "upkf:generate": "node scripts/upkf/generate-artifacts-v2.mjs",
    "upkf:verify": "node scripts/upkf/verify-artifacts.mjs",
    "upkf:check": "npm run upkf:generate && npm run upkf:verify",
    "seo:validate": "node scripts/seo/validate-pre-deploy.mjs",
    "seo:rich-results": "node scripts/seo/validate-rich-results.mjs",
    "seo:llms": "node scripts/seo/generate-llms-txt.mjs",
    "i18n:parity": "node scripts/i18n/validate-parity.mjs",
    "i18n:artifacts": "node --env-file=.env.local scripts/i18n/translate-generated-artifacts.mjs",
    "i18n:artifacts:dry": "node --env-file=.env.local scripts/i18n/translate-generated-artifacts.mjs --dry-run",
    "i18n:full-check": "npm run upkf:generate && npm run i18n:artifacts && npm run i18n:parity",
    "research:generate": "node scripts/research/generate-manuscripts.mjs",
    "research:check": "node scripts/research/generate-manuscripts.mjs && node scripts/research/score-and-verify.mjs",
    "predev": "echo 'Skipping upkf:generate during dev; run npm run upkf:generate manually when needed.'",
    "prebuild": "npm run upkf:generate && node scripts/seo/generate-llms-txt.mjs",
    "dev": "next dev --webpack",
    "dev:turbopack": "next dev --turbopack",
    "build": "npm run upkf:generate && node scripts/seo/generate-llms-txt.mjs && next build",
    "start": "next start",
    "lint": "eslint",
    "lint:md": "markdownlint 'docs/**/*.md' 'CHANGELOG.md' 'README.md' --config .markdownlint.json --ignore '**/**.generated.md'",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:coverage-ui": "vitest --coverage --ui",
    "test:e2e": "npx playwright test",
    "sota:check": "node scripts/sota-validate.mjs --skip-build",
    "sota:full": "node scripts/sota-validate.mjs",
    "links:inventory": "npm run upkf:generate",
    "seo:indexnow": "INDEXNOW_ENABLED=1 node scripts/seo/ping-indexnow.mjs",
    "content:publish": "node --env-file=.env.local scripts/content/publish.mjs",
    "content:publish:dry": "node --env-file=.env.local scripts/content/publish.mjs --dry-run",
    "prepare": "husky"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@tailwindcss/typography": "^0.5.19",
    "framer-motion": "^12.34.3",
    "gray-matter": "^4.0.3",
    "jszip": "^3.10.1",
    "lucide-react": "^0.562.0",
    "next": "16.1.2",
    "next-mdx-remote": "^6.0.0",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "eslint": "^9",
    "eslint-config-next": "16.1.2",
    "husky": "^9.1.7",
    "markdownlint-cli": "^0.48.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
